# ─── Site ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Esytol

# ─── Analytics (optional) ────────────────────────────────────────────────────
# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=
# Microsoft Clarity project ID (e.g. xxxxxxxxxx)
NEXT_PUBLIC_CLARITY_ID=

# ─── Ads (optional) ──────────────────────────────────────────────────────────
NEXT_PUBLIC_ADSENSE_ID=

# ─── Admin access (P0-2) ─────────────────────────────────────────────────────
# HTTP Basic credentials for every /admin route, enforced by middleware.ts.
# FAIL-CLOSED: while these are unset, /admin returns 401 for EVERYONE (including
# you). Set both in the deployment environment to unlock the dashboards.
# Server-side only — never NEXT_PUBLIC, never committed.
ADMIN_USER=
ADMIN_PASSWORD=

# ─── Growth Dashboard providers (/admin/growth) ──────────────────────────────
# Each provider goes live when its variables are set; otherwise the dashboard
# shows deterministic sample data. Server-side only — never commit real secrets.

# Google Analytics (GA4) via a Google Service Account:
#   1. Create a Service Account in Google Cloud, download its JSON key.
#   2. In GA4 Admin → Property Access, grant the service-account email "Viewer".
#   3. Set the numeric property ID and provide the key (file path OR inline):
GA4_PROPERTY_ID=
GOOGLE_APPLICATION_CREDENTIALS=
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","client_email":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"}
# Or a pre-minted OAuth token instead of a Service Account:
# GOOGLE_ACCESS_TOKEN=

# Google Search Console
GSC_SITE_URL=
# Microsoft Clarity
CLARITY_API_TOKEN=
# GitHub
GITHUB_TOKEN=
GITHUB_REPO=EasyTechLabs/esytol
# Vercel
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=
