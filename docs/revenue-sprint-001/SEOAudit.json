  "defects": [
    {
      "id": "SEO-D1",
      "severity": "high",
      "title": "FAQ answers absent from server-rendered HTML",
      "evidence": "features/tool/FAQSection.tsx:12,47 — answer <dd> renders only when expanded; SSR emits questions only. Answers survive only in FAQPage JSON-LD.",
      "affects": "all 37 tools",
      "fix": "Render answers server-side (details/summary or SSR-open), keep client toggle for UX."
    },
    {
      "id": "SEO-D2",
      "severity": "medium",
      "title": "Boilerplate FAQ answers duplicated across tools",
      "evidence": "registry/index.ts privacy/upload answers near-identical across emi/gst/sip/fd/rd/ppf/cagr and dev tools.",
      "affects": "finance + developer clusters",
      "fix": "Rewrite each FAQ answer tool-specifically; remove shared sentences."
    },
    {
      "id": "SEO-D3",
      "severity": "medium",
      "title": "Thin pages: base64-encoder, url-encoder",
      "evidence": "1-line description + 2-3 FAQ (registry:79-131).",
      "affects": "base64-encoder, url-encoder",
      "fix": "Expand description + add worked examples + how-it-works content."
    },
    {
      "id": "SEO-D4",
      "severity": "low",
      "title": "Dead/buggy OG helper seo/og.ts",
      "evidence": "toolOg hardcodes siteConfig.url (homepage) + static image; referenced nowhere.",
      "affects": "none (latent)",
      "fix": "Delete or fix."
    },
    {
      "id": "SEO-D5",
      "severity": "low",
      "title": "noindex guard only in catch-all, not buildToolMetadata",
      "evidence": "app/tools/[slug]/page.tsx:27-29 vs dedicated pages call buildToolMetadata directly.",
      "affects": "latent (future coming-soon dedicated pages)",
      "fix": "Move isToolLive→noindex into buildToolMetadata."
    },
    {
      "id": "SEO-D6",
      "severity": "low",
      "title": "Low-value keywords meta + site-wide keyword dilution",
      "evidence": "seo/metadata.ts:33 merges 10 site-wide keywords into every tool.",
      "affects": "all tools",
      "fix": "Drop keywords meta or make per-tool unique."
    },
    {
      "id": "SEO-D7",
      "severity": "medium",
      "title": "No google-site-verification / GSC coverage confirmation",
      "evidence": "grep found no verification meta; OBSERVATION.md Gate 0 pending.",
      "affects": "whole site",
      "fix": "Add verification, confirm indexation of 58 sitemap URLs."
    }
  ],
